{

/*------------------------------------
    Module-Left:
	Logo OS: оңҸ у°•Ҳ пҢ” у°җҝ у°Јӯ у°Җө пҢ’ у°ҢҪ у°ЈЁ у°Јӣ пҢҖ пү° оңҺ пҢҒ у°ЈҮ у°ЈҮ пҢ„ у°Јҡ уұ„ӣ уұ„ӣ 
	Workspaces
	App in use
-------------------------------------*/
"custom/logo": {
    "format": "у°Јӣ",
    "tooltip": false,
    "on-click": "rofi -show drun -p 'Apps'",
    "on-click-right": "swaymsg reload",
    "tooltip-format": "Sistema: {}"
},

"sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
	"focused": "у°ҶҰ",
	"default": "у°Ҷ§",
        "urgent": "уұ“»" 
    },
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": true
},


"sway/window": {
    "format": "",
    "max-length": 60,
    "icon": true,
    "icon-size": 20
},


/*------------------------------------
    Module-Center:
	Calendar(date)
	Clock(time)
	Weather, sometimes wttr can produces issues 
-------------------------------------*/

"clock#date": { 
    "format": " {:%a %d оӘ° |}",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
	"mode": "month",
	"mode-mon-col": 3,
	"on-click-right": "mode",
	"format": {
	    "months": "<span color='#ffead3'><b>{}</b></span>",
	    "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
	    "today": "<span color='#ff3355'><b>{}</b></span>"
	},
	"on-click": "tooltip"
    }
},

"clock#time": { 
    "format": "{:%H:%M пҖ— } |",
    "tooltip": true,
    "interval": 600
},

"custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 600,
    "return-type": "json",
    "interval": 1800, 
    "exec": "~/.config/waybar/scripts/weather2.sh",
//    "exec": "curl -s 'https://wttr.in/Guadalajara+Jalisco?format=%c+%t'",
//    "exec": "curl -s 'https://wttr.in/Guadalajara+Jalisco?format=%t+%c' | sed 's/  / /g' | sed 's/вҳҖпёҸ/у°–Ё/g' | sed 's/вҳҒпёҸ/у°–җ/g' | sed 's/вӣ…/у°–•/g' | sed 's/рҹҢ§пёҸ/у°––/g' | sed 's/вӣҲпёҸ/у°–“/g' | sed 's/вқ„пёҸ/у°ј¶/g'",
    "on-click": "xdg-open https://wttr.in/Guadalajara+Jalisco"
},


/*------------------------------------
    Module-Right:
	Brightness
	Audio
	Network
	Bluetooth
	Battery
	**Power options* In Process
-------------------------------------*/
"backlight": {
    "format": "{icon} {percent}%",
    "format": "{icon}",
    "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"],
    "on-scroll-up": "brightnessctl set 2.5%+",
    "on-scroll-down": "brightnessctl set 2.5%-"
},


"pulseaudio": {
//    "format": "{icon} {volume}%",
    "format": "{icon}",
    "format-muted": "у°–Ғ",
    "format-icons": {
	"headphone": "пҖҘ",
        "phone": "пӮ•",
        "portable": "пӮ•",
	"default": ["пҖҰ", "пҖ§", "пҖЁ"]
    },
    "on-click": "pavucontrol"
},

"network": {
//    "format-wifi": "пҮ«  {signalStrength}%",
    "format-wifi": "пҮ« ",
    "format-ethernet": "у°ҲҖ",
    "format-disconnected": "у°–Ә",
    "on-click": "nm-connection-editor"
},

"bluetooth": {
    "format": "у°ӮҜ",
    "format-connected": "у°Ӯұ",
    "format-connected-battery": "у°Ҙү {device_alias} {device_battery_percentage}%",
    "format-disabled": "у°ӮІ",
    "on-click": "blueman-manager"
},

"battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "пғ§ {capacity}%",
    "format-icons": [
	"пү„",
	"пүғ",
	"пүӮ",
	"пүҒ",
	"пүҖ"
    ],
    "on-click": "powerprofilesctl set performance",
    "on-click-right": "powerprofilesctl set power-saver",
    "on-click-middle": "powerprofilesctl set balanced"
},

"custom/power": {
    "format": "вҸ»",
    "tooltip": false,
    "on-click": "wlogout", 
    "on-click-right": "swaylock"
}

}
