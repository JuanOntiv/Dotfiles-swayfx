"$schema" = 'https://starship.rs/config-schema.json'

#[‚ĒŹ](color2)\
#[Óāį](bg:color2 fg:color2)\
#$os\
#[Óāį](bg:color3 fg:color2)\
#$username\
#[Óāį](bg:color4 fg:color3)\

format = """
[‚ĒŹ](color3)\
[Óāį](bg:color3 fg:color11)\
$username\
[Óāį](bg:color4 fg:color3)\
$directory\
[Óāį](bg:color7 fg:color4)\
$custom\
[Óāį](bg:color5 fg:color7)\
$git_branch\
$git_status\
[Óāį](fg:color5 bg:color6)\
$c\
$cpp\
$rust\
$golang\
$nodejs\
$php\
$java\
$kotlin\
$haskell\
$python\
[Óāį ](color6)
[‚Ēó‚ĒĀ](color3)\
$character
"""
palette = 'sand'

scan_timeout = 1000

[os]
disabled = false
style = "bg:color2 fg:color1"

[os.symbols]
Raspbian = "ůįźŅ"
Manjaro = "ÔĆí"
Linux = "ůįĆĹ"
Gentoo = "ůį£®"
Fedora = "ůį£õ "
Alpine = "ÔĆÄ"
Amazon = "ÔČį"
CentOS = "ÔĆĄ"
Debian = "ůį£ö"
Redhat = "ůĪĄõ"
RedHatEnterprise = "ůĪĄõ"

[username]
show_always = true
style_user = "bg:color3 fg:color1"
style_root = "bg:color3 fg:color1"
format = '[ $user ]($style)'

[directory]
style = "bg:color4 fg:color1"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "‚Ä¶/"

[directory.substitutions]
"Apps" = "ůįÄĽ "
"Books" = "ůĪď∑ "
"Desktop" = "Ôí© "
"Developer" = "ůį≤č "
"Documents" = "ůįąô "
"Downloads" = "ÔÄô "
"Music" = "ůįĚö "
"Pictures" = "ÔÄĺ "
".config" = "Óėē "

[git_branch]
symbol = "Ôźė"
style = "bg:color5"
format = '[[ $symbol $branch ](fg:color1 bg:color5)]($style)'

[git_status]
style = "bg:color5"
format = '[[($all_status$ahead_behind )](fg:color1 bg:color5)]($style)'

[nodejs]
symbol = "Óúė"
style = "bold color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[c]
symbol = "Óėě "
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[cpp]
disabled = false
symbol = "ÓėĚ "
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[rust]
symbol = "Óě®"
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[golang]
symbol = "ůįüď"
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[php]
symbol = "Óėą"
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[java]
symbol = "ÓČĖ "
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[kotlin]
symbol = "Óėī"
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[haskell]
symbol = "Óėü"
style = "bg:color6"
format = '[[ $symbol( $version) ](fg:color1 bg:color6)]($style)'

[python]
symbol = "ÓėÜ"
style = "bg:color6"
format = '[[ $symbol( $version)(\(#$virtualenv\)) ](fg:color1 bg:color6)]($style)'

[docker_context]
symbol = "ÔĆą"
style = "bg:color8"
format = '[[ $symbol( $context) ](fg:color1 bg:color8)]($style)'

#[custom.docker]
#command = "echo 'Ôąü'"
#when = "pgrep dockerd"
#format = "[[ $output ](fg:color1 bg:color7)]($style)"
#style = "blue"

#
#[custom.jenkins]
#command = "echo 'Ôč¨'"
#when = "docker ps | grep jenkins"
#format = "[[ $output ](fg:color1 bg:color7)]($style)"
#style = "yellow"

[custom.ngrok]
command = "echo 'ÓĚ∂'"
when = "pgrep ngrok"
format = "[[ ÓĚ∂ ](fg:color1 bg:color7)]($style)"
style = "green"

[character]
disabled = false
success_symbol = '[‚ĚĮ](bold fg:color3)'
error_symbol = '[‚ĚĮ](bold fg:color4)'
vimcmd_symbol = '[‚Ěģ](bold fg:color5)'
vimcmd_replace_one_symbol = '[‚Ěģ](bold fg:color9)'
vimcmd_replace_symbol = '[‚Ěģ](bold fg:color9)'
vimcmd_visual_symbol = '[‚Ěģ](bold fg:color10)'

[cmd_duration]
show_milliseconds = true
format = "Óęī in $duration "
style = "bg:color9"
disabled = true
show_notifications = true
min_time_to_notify = 45000


[palettes.watermelon]
color1 = "#181926"
color2 = "#B42C41"
color3 = "#D93B54"
color4 = "#f15a61"
color5 = "#71A95A"
color6 = "#458924"
color7 = "#aae140"
color8 = "#209fb5"
color9 = "#7287fd"
color10 = "#df8e1d"

